# OpenAI（必填）
# - 启动：对全库种子 text-embedding-3-small 建 JD 组卷索引
# - AI 出题与评卷：Chat Completions
OPENAI_API_KEY=sk-your-key-here

# 可选：JD 混卷策略（真题优先，只有真题短缺才提升 AI 比例）
# JD_BASE_AI_RATIO_EVERY=5
# JD_UNSEEN_SUFFICIENT_MULTIPLIER=2
# JD_SEEN_RATIO_MID=0.5
# JD_SEEN_RATIO_HIGH=0.8
# JD_SHORTFALL_EXTRA_DIV=2

# 可选：JD Planner→Selector 候选池（每 topic 条数上限、总条数上限）
# JD_CANDIDATE_PER_TOPIC=12
# JD_SELECTOR_MAX_ITEMS=96

# 可选：覆盖默认 Base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# 可选：Tutor Knowledge RAG / Query Rewrite
# QUERY_REWRITE_MODEL=gpt-4o-mini
# KNOWLEDGE_RAG_TOP_K=6
# KNOWLEDGE_INITIAL_K=30

# Hybrid 检索 + BGE Rerank（两系统通用）
# HYBRID_ENABLED=true
# HYBRID_ALPHA=0.4
# RETRIEVE_INITIAL_K=30
# RERANK_ENABLED=true
# RERANK_MODEL=BAAI/bge-reranker-base
# JD_INITIAL_K=30
# JD_RERANK_TOP_N=15
# JD_DEBUG_RETRIEVAL=false
# 知识库 FAISS：默认落盘到 data/knowledge/faiss_index/；语料 json 变更或模型/分块参数变更会自动重建
# KNOWLEDGE_FAISS_REBUILD=true
# KNOWLEDGE_FAISS_PATH=C:\path\to\custom\faiss_index

# 可选：CORS（n8n 本地 UI Quick Tunnel 联调）
# APP_ENV=development
# 与上面等价效果之一：允许任意 Origin（此时关闭 credentials，符合浏览器规范）
# DEV_CORS_ALLOW_ALL=true
